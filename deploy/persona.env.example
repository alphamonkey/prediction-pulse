# Per-persona secrets — copy to secrets/<persona>.env (gitignored; never commit).
# Loaded by pulse@<persona>.service via EnvironmentFile= and by `pulse supervise <persona>`.

# dryrun = detect/draft but never post/engage. Flip to live per persona, after reviewing copy.
PULSE_MODE=dryrun

# The persona's own Bluesky account (app password from Settings → App Passwords).
BLUESKY_HANDLE=yourpersona.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# The persona's own Mastodon account. Only needed if persona.toml declares a mastodon channel —
# the instance URL lives THERE (it's config, not a secret); this token is the whole credential
# (it identifies the account, so there's no handle to set). Create it under
# Preferences → Development → New application, with the write:statuses, write:favourites,
# write:follows and read:accounts scopes.
MASTODON_ACCESS_TOKEN=

# Claude writes the post copy; without a key the zero-cost template writer is used.
ANTHROPIC_API_KEY=
